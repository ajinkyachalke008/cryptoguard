# ===========================================
# CryptoGuard Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values

# Application Settings
NODE_ENV=development
PORT=3000

# Database Configuration (Turso SQLite)
# Get your database URL and auth token from: https://turso.tech
TURSO_DATABASE_URL=libsql://your-database-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Alternative: Local SQLite database
# DATABASE_URL=file:./local.db

# Authentication & Security
JWT_SECRET=your-secure-jwt-secret-change-this-in-production
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# Web3 / Blockchain API Keys (Optional - uses mock data if not set)
# Etherscan: https://etherscan.io/apis
WEB3_API_KEY=your-web3-api-key
ETHERSCAN_API_KEY=your-etherscan-api-key

# Moralis: https://moralis.io
MORALIS_API_KEY=your-moralis-api-key

# Alchemy: https://alchemy.com
ALCHEMY_API_KEY=your-alchemy-api-key

# AI Provider Configuration (Optional - uses mock explanations if not set)
# OpenAI: https://platform.openai.com/api-keys
AI_API_KEY=your-openai-or-ai-api-key
AI_API_URL=https://api.openai.com/v1/chat/completions
AI_MODEL=gpt-4

# Alternative AI Providers:
# Anthropic Claude: https://console.anthropic.com
# AI_API_URL=https://api.anthropic.com/v1/messages
# AI_MODEL=claude-3-opus-20240229

# Google Gemini: https://ai.google.dev
# AI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-pro:generateContent
# AI_MODEL=gemini-pro

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:4000

# Stripe Payment Integration (Optional)
# Get your keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_TEST_KEY=sk_test_your_test_key
STRIPE_LIVE_KEY=sk_live_your_live_key

# Better Auth Configuration (Auto-configured by auth agent)
BETTER_AUTH_SECRET=your-better-auth-secret
BETTER_AUTH_URL=http://localhost:3000

# Autumn Payments Configuration (Auto-configured by payments agent)
AUTUMN_SECRET_KEY=your-autumn-secret-key

# ===========================================
# Development Notes
# ===========================================

# Required for basic functionality:
# - TURSO_DATABASE_URL and TURSO_AUTH_TOKEN (or DATABASE_URL for local SQLite)
# - JWT_SECRET (use a strong random string in production)

# Optional but recommended:
# - WEB3_API_KEY or ETHERSCAN_API_KEY (for real blockchain data)
# - AI_API_KEY (for AI-powered risk explanations)
# - STRIPE_SECRET_KEY (for payment features)

# The backend will work with mock data if API keys are not provided.
# Set NODE_ENV=production for production deployments.

# Security Tips:
# 1. Never commit .env file to version control
# 2. Use strong, unique secrets for JWT_SECRET
# 3. Rotate API keys regularly
# 4. Use different keys for development and production
# 5. Enable rate limiting in production
# 6. Use HTTPS in production
