{
  "manifest_version": 3,
  "name": "CryptoGuard — AI Security Companion",
  "version": "1.0.0",
  "description": "Real-time blockchain forensics and fraud detection in your browser.",
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "activeTab"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
